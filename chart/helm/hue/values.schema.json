{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Hue Helm Chart Values",
  "description": "Schema for validating Hue and Trino deployment configurations.",
  "type": "object",
  "definitions": {
    "stringMap": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "stringOrNull": {
      "type": ["string", "null"]
    },
    "stringArray": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "properties": {
    "env": {
      "type": ["array", "null"],
      "default": null,
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "value": { "type": "string" },
          "valueFrom": { "type": "object", "additionalProperties": true }
        },
        "required": ["name"],
        "additionalProperties": true
      }
    },
    "image": {
      "type": "object",
      "properties": {
        "registry": { "type": "string", "default": "ghcr.io/netcracker/qubership-hue" },
        "tag": { "type": "string", "default": "main" },
        "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"], "default": "IfNotPresent" }
      },
      "required": ["registry", "tag"],
      "additionalProperties": true
    },
    "api": {
      "type": "object",
      "properties": {
        "enabled": { "type": ["boolean", "string"], "default": false },
        "domain": { "type": "string", "default": "api." }
      },
      "additionalProperties": true
    },
    "hue": {
      "type": "object",
      "properties": {
        "priorityClassName": { "$ref": "#/definitions/stringOrNull", "default": null },
        "replicas": { "type": ["integer", "string"], "minimum": 1, "default": 1 },
        "resources": {
          "type": "object",
          "properties": {
            "limits": {
              "type": "object",
              "properties": {
                "cpu": {
                  "type": "string",
                  "pattern": "^([0-9]+m|[0-9]+(\\.[0-9]+)?)$",
                  "default": "300m"
                },
                "memory": {
                  "type": "string",
                  "pattern": "^[0-9]+(Mi|Gi|Ki|Ti)$",
                  "default": "500Mi"
                }
              },
              "additionalProperties": true
            },
            "requests": {
              "type": "object",
              "properties": {
                "cpu": {
                  "type": "string",
                  "pattern": "^([0-9]+m|[0-9]+(\\.[0-9]+)?)$",
                  "default": "200m"
                },
                "memory": {
                  "type": "string",
                  "pattern": "^[0-9]+(Mi|Gi|Ki|Ti)$",
                  "default": "300Mi"
                }
              },
              "additionalProperties": true
            }
          },
          "additionalProperties": true
        },
        "service": {
          "type": "object",
          "properties": {
            "annotations": { "$ref": "#/definitions/stringMap", "default": {} }
          },
          "additionalProperties": true
        },
        "database": {
          "type": "object",
          "properties": {
            "create": { "type": ["boolean", "string"], "default": true },
            "initJobAnnotations": {
              "type": "object",
              "properties": {
                "helm.sh/hook": {
                  "type": "string",
                  "default": "pre-install"
                },
                "helm.sh/hook-delete-policy": {
                  "type": "string",
                  "default": "before-hook-creation,hook-succeeded,hook-failed"
                },
                "helm.sh/hook-weight": {
                  "type": "string",
                  "default": "-4"
                }
            },
            "additionalProperties": true
          },
            "engine": { "type": "string", "default": "postgresql_psycopg2" },
            "host": { "type": "string", "default": "pg-patroni.postgres.svc" },
            "port": { "type": ["integer", "string"], "minimum": 1, "maximum": 65535, "default": 5432 },
            "user": { "type": "string", "default": "user" },
            "password": { "type": "string", "default": "password" },
            "name": { "type": "string", "default": "postgres" },
            "adminUser": { "type": "string", "default": "admin user name" },
            "adminPassword": { "type": "string", "default": "admin password" }
          },
          "additionalProperties": true
        },
        "imagePullPolicy": { "type": "string", "default": "Always" },
        "podSecurityContext": {
          "type": "object",
          "properties": {
            "runAsUser": { "type": ["integer", "string"], "default": 1001 },
            "fsGroup": { "type": ["integer", "string"], "default": 1001 }
          },
          "additionalProperties": true
        },
        "securityContext": {
          "type": "object",
          "properties": {
            "readOnlyRootFilesystem": { "type": ["boolean", "string"], "default": true },
            "allowPrivilegeEscalation": { "type": ["boolean", "string"], "default": false },
            "runAsNonRoot": { "type": ["boolean", "string"], "default": true },
            "capabilities": {
              "type": "object",
              "properties": {
                "drop": {
                  "type": "array",
                  "items": { "type": "string", "default": "ALL"}
                }
              },
              "additionalProperties": true
            },
            "seccompProfile": {
              "type": "object",
              "properties": {
                "type": { "type": "string" }
              },
              "additionalProperties": true
            }
          },
          "additionalProperties": true
        },
        "hostAliases": {
          "type": "array",
          "default": [],
          "items": { "type": "object", "additionalProperties": true }
        },
        "interpreters": {"type": "string"},
        "ini": { "type": "string"}
      },
      "required": ["database"],
      "additionalProperties": true
    },
    "createDBJob": {
      "type": "object",
      "properties": {
        "resources": {
          "type": "object",
          "properties": {
            "limits": {
              "type": "object",
              "properties": {
                "cpu": {
                  "type": "string",
                  "pattern": "^([0-9]+m|[0-9]+(\\.[0-9]+)?)$",
                  "default": "500m"
                },
                "memory": {
                  "type": "string",
                  "pattern": "^[0-9]+(Mi|Gi|Ki|Ti)$",
                  "default": "512Mi"
                }
              },
              "additionalProperties": true
            },
            "requests": {
              "type": "object",
              "properties": {
                "cpu": {
                  "type": "string",
                  "pattern": "^([0-9]+m|[0-9]+(\\.[0-9]+)?)$",
                  "default": "300m"
                },
                "memory": {
                  "type": "string",
                  "pattern": "^[0-9]+(Mi|Gi|Ki|Ti)$",
                  "default": "300Mi"
                }
              },
              "additionalProperties": true
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "ingress": {
      "type": "object",
      "properties": {
        "create": { "type": ["boolean", "string"], "default": true },
        "type": { "type": "string", "default": "nginx" },
        "domain": { "type": "string", "default": "" },
        "tls": {
          "type": "object",
          "properties": {
            "enabled": { "type": ["boolean", "string"], "default": false },
            "secretName": { "$ref": "#/definitions/stringOrNull" }
          },
          "additionalProperties": true
        },
        "annotations": { "$ref": "#/definitions/stringMap", "default": {} },
        "labels": { "$ref": "#/definitions/stringMap", "default": {} }
      },
      "additionalProperties": true
    },
    "hive": {
      "type": "object",
      "properties": {
        "site": { "type": "string" }
      },
      "additionalProperties": true
    },
    "ssl": {
      "type": "object",
      "properties": {
        "enabled": { "type": ["boolean", "string"], "default": false },
        "cacerts": { "type": "string" }
      },
      "additionalProperties": true
    },
    "kerberos": {
      "type": "object",
      "properties": {
        "enabled": { "type": ["boolean", "string"], "default": false },
        "keytab": { "type": "string" },
        "config": { "type": "string" }
      },
      "additionalProperties": true
    },
    "ldap": {
      "type": "object",
      "properties": {
        "enabled": { "type": ["boolean", "string"], "default": false },
        "bind_password_script": { "type": "string" }
      },
      "additionalProperties": true
    },
    "databasescommon": {
      "type": "object",
      "properties": {
        "enabled": { "type": ["boolean", "string"], "default": false },
        "configs": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      },
      "additionalProperties": true
    },
    "trino": {
      "type": "object",
      "properties": {
        "enabled": { "type": ["boolean", "string"], "default": false },
        "image": { "type": "string", "default": "ghcr.io/netcracker/qubership-trino:main" },
        "imagePullPolicy": { "type": "string", "default": "IfNotPresent" },
        "replicas": { "type": ["integer", "string"], "minimum": 1, "default": 1 },
        "priorityClassName": { "$ref": "#/definitions/stringOrNull" },
        "livenessProbe": { "type": "object", "additionalProperties": true },
        "readinessProbe": { "type": "object", "additionalProperties": true },
        "resources": {
          "type": "object",
          "properties": {
            "limits": {
              "type": "object",
              "properties": {
                "cpu": {
                  "type": "string",
                  "pattern": "^([0-9]+m|[0-9]+(\\.[0-9]+)?)$",
                  "default": "150m"
                },
                "memory": {
                  "type": "string",
                  "pattern": "^[0-9]+(Mi|Gi|Ki|Ti)$",
                  "default": "800Mi"
                }
              },
              "additionalProperties": true
            },
            "requests": {
              "type": "object",
              "properties": {
                "cpu": {
                  "type": "string",
                  "pattern": "^([0-9]+m|[0-9]+(\\.[0-9]+)?)$",
                  "default": "100m"
                },
                "memory": {
                  "type": "string",
                  "pattern": "^[0-9]+(Mi|Gi|Ki|Ti)$",
                  "default": "600Mi"
                }
              },
              "additionalProperties": true
            }
          },
          "additionalProperties": true
        },
        "service": {
          "type": "object",
          "properties": {
            "annotations": { "$ref": "#/definitions/stringMap", "default": {} }
          },
          "additionalProperties": true
        },
        "securityContext": {
          "type": "object",
          "properties": {
            "readOnlyRootFilesystem": { "type": ["boolean", "string"], "default": true },
            "allowPrivilegeEscalation": { "type": ["boolean", "string"], "default": false },
            "runAsNonRoot": { "type": ["boolean", "string"], "default": true },
            "capabilities": {
              "type": "object",
              "properties": {
                "drop": {
                  "type": "array",
                  "items": { "type": "string", "default": "ALL"}
                }
              },
              "additionalProperties": true
            },
            "seccompProfile": {
              "type": "object",
              "properties": {
                "type": { "type": "string" }
              },
              "additionalProperties": true
            }
          },
          "additionalProperties": true
        },
        "podSecurityContext": {
          "type": "object",
          "properties": {
            "runAsUser": { "type": ["integer", "string"], "default": 1000 },
            "runAsGroup": { "type": ["integer", "string"], "default": 1000 }
          },
          "additionalProperties": true
        },
        "hostAliases": {
          "type": "array",
          "default": [],
          "items": { "type": "object", "additionalProperties": true }
        },
        "extraVolumes": {
          "type": "array",
          "default": [],
          "items": { "type": "object", "additionalProperties": true }
        },
        "extraVolumeMounts": {
          "type": "array",
          "default": [],
          "items": { "type": "object", "additionalProperties": true }
        }
      },
      "additionalProperties": true
    },
    "jvmconfig": { "type": "string" },
    "jvm": {
      "type": "object",
      "properties": {
        "maxHeapSize": { "type": "string", "default": "1G" },
        "gcMethod": {
          "type": "object",
          "properties": {
            "type": { "type": "string", "default": "UseG1GC" },
            "g1": {
              "type": "object",
              "properties": {
                "heapRegionSize": { "type": "string", "default": "16M" }
              },
              "additionalProperties": true
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "certManagerInegration": {
      "type": "object",
      "properties": {
        "enabled": { "type": ["boolean", "string"], "default": false },
        "secretName": { "type": "string", "default": "hue-tls-cm" },
        "secretMounts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "mountPath": { "type": "string", "default": "/home/hue/trustcerts/ca.crt" },
              "subPath": { "type": "string", "default": "ca.crt" }
            },
            "required": ["mountPath"],
            "additionalProperties": true
          }
        },
        "duration": { "type": ["integer", "string"], "default": 365 },
        "subjectAlternativeName": {
          "type": "object",
          "properties": {
            "additionalDnsNames": { "$ref": "#/definitions/stringArray", "default": [] },
            "additionalIpAddresses": { "$ref": "#/definitions/stringArray", "default": [] }
          },
          "additionalProperties": true
        },
        "clusterIssuerName": { "$ref": "#/definitions/stringOrNull", "default": null }
      },
      "additionalProperties": true
    },
    "extraSecrets": {
      "type": "object",
      "additionalProperties": true
    },
    "extraVolumes": {
      "type": "array",
      "default": [],
      "items": { "type": "object", "additionalProperties": true }
    },
    "extraVolumeMounts": {
      "type": "array",
      "default": [],
      "items": { "type": "object", "additionalProperties": true }
    },
    "gateway": {
      "type": "object",
      "properties": {
        "enabled": { "type": ["boolean", "string"], "default": false },
        "annotations": { "$ref": "#/definitions/stringMap", "default": {} },
        "labels": { "$ref": "#/definitions/stringMap", "default": {} },
        "parentRefs": {
          "type": "array",
          "default": [],
          "items": { "type": "object", "additionalProperties": true }
        },
        "hostnames": { "$ref": "#/definitions/stringArray", "default": [] },
        "rules": {
          "type": "array",
          "default": [],
          "items": { "type": "object", "additionalProperties": true }
        },
        "redirectRoute": {
          "type": "object",
          "properties": {
            "enabled": { "type": ["boolean", "string"], "default": false },
            "parentRefs": {
              "type": "array",
              "default": [],
              "items": { "type": "object", "additionalProperties": true }
            }
          },
          "additionalProperties": true
        },
        "backendTLSPolicy": {
          "type": "object",
          "properties": {
            "enabled": { "type": ["boolean", "string"], "default": false },
            "hostname": { "type": "string", "default": "" },
            "caCertificateRefs": {
              "type": "array",
              "default": [],
              "items": { "type": "object", "additionalProperties": true }
            },
            "wellKnownCACertificates": { "type": "string", "default": "" },
            "subjectAltNames": { "$ref": "#/definitions/stringArray", "default": [] }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
